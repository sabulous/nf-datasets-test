{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "CSV input example",
  "type": "object",
  "definitions": {
    "input_output_options": {
      "title": "Input/output options",
      "type": "object",
      "required": ["input"],
      "properties": {
        "input": {
          "type": "string",
          "format": "file-path",
          "mimetype": "text/csv",
          "pattern": "^\\S+\\.csv$",
          "description": "Path to the CSV dataset to use as pipeline input."
        }
      }
    }
  },
  "allOf": [
    { "$ref": "#/definitions/input_output_options" }
  ]
}